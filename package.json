{
  "name": "vsquirrel",
  "displayName": "vsquirrel",
  "description": "VScod{e,ium} extension for Squirrel proof assistant.",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "zacharie-moughanim",
  "icon": "./icons/squirrel_logo.png",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacharie-moughanim/vsquirrel.git"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vsquirrel.killServer",
        "title": "Kill LSP server"
      },
      {
        "command": "vsquirrel.nextProof",
        "title": "Proof Next Point"
      },
      {
        "command": "vsquirrel.startProof",
        "title": "Start Proof",
        "icon": "$(file-code)"
      }
    ],
    "configuration": {
      "title": "Squirrel Prover",
      "type": "object",
      "properties": {
        "SquirrelProver.lsp.pythonInterpreterPath": {
          "type": "string",
          "markdownDescription": "Path to a python interpreter used to run the LSP server. default:python",
          "default": "python",
          "order": 0
        },
        "SquirrelProver.squirrelPath": {
          "type": "string",
          "markdownDescription": "Path to squirrel. default:~/squirrel-prover/squirrel",
          "default": "~/squirrel-prover/squirrel",
          "order": 1
        }
      }
    },
    "languages": [
      {
        "id": "squirrel-prover",
        "extensions": [
          ".sp"
        ],
        "aliases": [
          "SquirrelProver"
        ],
        "filenames": [],
        "configuration": "./squirrel-prover-language-configuration.json",
        "icon": {
          "light": "./icons/squirrel_light.png",
          "dark": "./icons/squirrel_dark.png"
        }
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "resourceLangId == squirrel-prover && editorTextFocus",
          "command": "vsquirrel.startProof"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vsquirrel.nextProof",
        "key": "alt+down",
        "mac": "ctrl+alt+down",
        "when": "resourceLangId == squirrel-prover && editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
